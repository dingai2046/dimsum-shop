# 站点 URL（Vercel 部署后填实际域名）
NEXT_PUBLIC_SITE_URL="https://your-domain.vercel.app"

# Supabase PostgreSQL（使用 Session pooler）
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres"

# NextAuth.js（用 openssl rand -hex 32 生成）
AUTH_SECRET=""

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# 微信开放平台（可选）
WECHAT_APP_ID=""
WECHAT_APP_SECRET=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
