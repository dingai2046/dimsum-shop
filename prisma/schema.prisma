// Dimsum Shop - 东方点心 数据库 Schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==================== 枚举 ====================

enum UserRole {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING     // 待支付
  PAID        // 已支付
  PROCESSING  // 处理中
  SHIPPED     // 已发货
  DELIVERED   // 已送达
  CANCELLED   // 已取消
  REFUNDED    // 已退款
}

enum PointsType {
  EARN        // 消费获得
  REDEEM      // 兑换使用
  ADJUST      // 手动调整
  EXPIRE      // 过期扣除
}

// ==================== 模型 ====================

model User {
  id        String   @id @default(cuid())
  email     String?  @unique
  phone     String?  @unique
  name      String?
  password  String?
  avatar    String?
  points    Int      @default(0)
  role      UserRole @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  addresses    Address[]
  orders       Order[]
  pointRecords PointsRecord[]

  @@map("users")
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  image       String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@map("categories")
}

model Product {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  description   String?
  price         Int      // 价格（分）
  originalPrice Int?     // 原价（分）
  image         String?
  images        String[] // 多图
  categoryId    String
  stock         Int      @default(0)
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  category   Category    @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]

  @@index([categoryId])
  @@map("products")
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  name      String   // 收件人姓名
  phone     String   // 收件人电话
  province  String
  city      String
  district  String
  detail    String   // 详细地址
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("addresses")
}

model Order {
  id              String      @id @default(cuid())
  orderNo         String      @unique
  userId          String
  addressSnapshot Json        // 下单时的地址快照
  totalAmount     Int         // 总金额（分）
  status          OrderStatus @default(PENDING)
  paymentId       String?     // Stripe Payment Intent ID
  note            String?     // 订单备注
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user         User           @relation(fields: [userId], references: [id])
  items        OrderItem[]
  pointRecords PointsRecord[]

  @@index([userId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id              String @id @default(cuid())
  orderId         String
  productId       String
  productSnapshot Json   // 下单时的产品快照（名称、价格、图片）
  quantity        Int
  price           Int    // 单价（分）

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

model PointsRecord {
  id          String     @id @default(cuid())
  userId      String
  orderId     String?
  points      Int        // 正数=获得，负数=使用
  type        PointsType
  description String?
  createdAt   DateTime   @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order Order? @relation(fields: [orderId], references: [id])

  @@index([userId])
  @@map("points_records")
}
